# Provider: mock | domestic_openai_compatible
LLM_PROVIDER=mock

# Domestic OpenAI-compatible API
LLM_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=your_domestic_api_key_here
LLM_MODEL=Qwen/Qwen3-8B
VISION_MODEL=Qwen/Qwen3-VL-8B-Instruct
VISION_ANALYSIS_MODE=auto

# Shared generation controls
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4000
VISION_TEMPERATURE=0.2

# Xiaohongshu publish (optional third-party webhook)
# mock: prepare copy + assets, open creator center manually
# webhook: POST prepared payload to XHS_PUBLISH_API_URL (scan QR to publish)
XHS_PUBLISH_PROVIDER=mock
XHS_PUBLISH_API_URL=
XHS_PUBLISH_API_KEY=
PUBLIC_BASE_URL=http://127.0.0.1:8001
